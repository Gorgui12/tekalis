# ===============================================
# TEKALIS - Configuration Environnement
# FICHIER EXEMPLE — NE PAS COMMITER LE .env RÉEL
# ===============================================
# Copier ce fichier : cp .env.example .env
# puis remplir les valeurs réelles dans .env
# Le .env NE DOIT JAMAIS être commité dans git

# ===============================================
# Environnement & Port
# ===============================================
NODE_ENV=development
PORT=5000

# ===============================================
# MongoDB Atlas
# ===============================================
# Remplacer par votre URI Atlas ou locale
MONGODB_URI=mongodb+srv://Gorgui12:Gorgui12@cluster0.gaktlzf.mongodb.net/?appName=Cluster0

# ===============================================
# JWT Authentication
# ===============================================
# OBLIGATOIRE : Générer une valeur aléatoire forte :
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=tekalis_super_secret_2026_secure_!@#_long_key_123456
JWT_EXPIRE=30d

# ===============================================
# Email Configuration SMTP (tekalis.com)
# ===============================================
EMAIL_HOST=mail.tekalis.com
EMAIL_PORT=465
EMAIL_USER=company@tekalis.com
EMAIL_PASS=Tekalis12

# Email admin pour recevoir les notifications commandes
# IMPORTANT : sans cette variable, les emails admin sont silencieux
ADMIN_EMAIL=admin@tekalis.com

# ===============================================
# URLs Frontend et Backend
# ===============================================
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000
API_URL=http://localhost:5000

# ===============================================
# CORS Origins (séparés par des virgules)
# Ces valeurs sont lues dynamiquement par server.js
# ===============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ===============================================
# Rate Limiting
# ===============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===============================================
# Blocage de domaines email temporaires (optionnel)
# Séparer par des virgules
# ===============================================
# BLOCKED_EMAIL_DOMAINS=mailinator.com,tempmail.com,guerrillamail.com

# ===============================================
# Configuration PayDunya
# ===============================================
PAYDUNYA_MODE=test

# Clés TEST PayDunya (à remplacer par vos vraies clés)
PAYDUNYA_MASTER_KEY=VOTRE_MASTER_KEY_PAYDUNYA
PAYDUNYA_PRIVATE_KEY=test_private_VOTRE_CLE_PRIVEE
PAYDUNYA_PUBLIC_KEY=test_public_VOTRE_CLE_PUBLIQUE
PAYDUNYA_TOKEN=VOTRE_TOKEN_PAYDUNYA

# ===============================================
# Configuration du Magasin (pour PayDunya)
# ===============================================
STORE_NAME=Tekalis - Boutique Tech
STORE_TAGLINE=Vente d'électronique et informatique
STORE_PHONE=221762145037
STORE_ADDRESS=Dakar, Fann, Sénégal
STORE_WEBSITE=http://localhost:3000
STORE_LOGO=http://localhost:3000/logo.png

# ===============================================
# Informations du site
# ===============================================
SITE_NAME=Tekalis

# ===============================================
# Cloudinary (Upload d'images - Optionnel)
# ===============================================
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ===============================================
# Redis (Cache - Optionnel)
# ===============================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ===============================================
# Debug
# ===============================================
DEBUG_MODE=true
